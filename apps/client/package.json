{
    "name": "client",
    "private": true,
    "version": "1.3.0",
    "description": "Mileto App Desktop",
    "author": "User",
    "type": "module",
    "main": "electron-main/main.cjs",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "make": "cd ../server && npm run build:bundle && cd ../client && vite build && electron-builder build --win",
        "lint": "eslint .",
        "preview": "vite preview",
        "electron:dev": "concurrently \"vite --port 5173 --strictPort\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\""
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "clsx": "^2.1.1",
        "electron-updater": "^6.8.3",
        "html-to-image": "^1.11.13",
        "lucide-react": "^0.563.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-dropzone": "^14.4.0",
        "react-router-dom": "^7.13.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.4.0",
        "tailwindcss-animate": "^1.0.7",
        "uuid": "^13.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.1",
        "@tailwindcss/postcss": "^4.1.18",
        "@types/node": "^24.10.1",
        "@types/react": "^19.2.5",
        "@types/react-dom": "^19.2.3",
        "@types/uuid": "^10.0.0",
        "@vitejs/plugin-react": "^5.1.1",
        "autoprefixer": "^10.4.24",
